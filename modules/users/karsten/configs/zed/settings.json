{
  "icon_theme": "Zed (Default)",
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "zed.dev",
      "model": "gpt-5.5",
      "enable_thinking": true,
      "effort": "medium"
    },
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "preview_tabs": {
    "enabled": false,
  },
  "status_bar": {
    "active_language_button": true,
  },
  "outline_panel": {
    "dock": "left",
    "folder_icons": true,
  },
  "project_panel": {
    "dock": "right",
    "button": true,
    "auto_fold_dirs": false,
    "hide_root": true,
    "folder_icons": false,
  },
  "vim_mode": false,
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "ensure_final_newline_on_save": false,
  "helix_mode": true,
  "ui_font_size": 16.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "dark",
    "light": "Light",
    "dark": "Gleam Dark",
  },
  "soft_wrap": "editor_width",
  "title_bar": {
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_sign_in": false,
  },
  "disable_ai": true,
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "lsp": {
    // "tinymist": {
    //   "settings": {
    //     "exportPdf": "onSave",
    //     "outputPath": "$root/$name",
    //   },
    // },
    "ruff": {
      "binary": {
        "path": "ruff",
        "arguments": ["server"],
      },
    },
  },
  "buffer_font_family": "DejaVu Sans Mono",
  "ui_font_family": "DejaVu Sans",
}
