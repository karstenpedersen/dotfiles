{
  "preview_tabs": {
    "enabled": false
  },
  "status_bar": {
    "active_language_button": true
  },
  "outline_panel": {
    "folder_icons": true
  },
  "project_panel": {
    "dock": "right",
    "button": true,
    "auto_fold_dirs": false,
    "hide_root": true,
    "folder_icons": false
  },
  "vim_mode": false,
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "ensure_final_newline_on_save": false,
  "helix_mode": true,
  "ui_font_size": 16.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Light"
  },
  "soft_wrap": "editor_width",
  "title_bar": {
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_sign_in": false
  },
  "disable_ai": true,
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false
  },
  "lsp": {
    "tinymist": {
      "settings": {
        "exportPdf": "onSave",
        "outputPath": "$root/$name"
      }
    },
    "haskell-language-server": {
      "binary": {
        "path": "haskell-language-server-wrapper",
        "arguments": ["lsp"]
      }
    }
  },
  "buffer_font_family": "DejaVu Sans Mono",
  "ui_font_family": "DejaVu Sans"
}
